# ============================================================
#  Erudios — Environment Configuration
#  Copy this file to .env and fill in your values
#  Run: cp .env.example .env
# ============================================================

# ── Application ──────────────────────────────────────────────
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-secret-in-production

# ── LLM Providers (at least ONE required) ───────────────────
# Gemini — https://aistudio.google.com/apikey  (Free: 1M tokens/day)
GEMINI_API_KEY=

# Groq — https://console.groq.com/keys  (Free: 1M tokens/day for Llama)
GROQ_API_KEY=

# HuggingFace — https://huggingface.co/settings/tokens  (Optional, improves embeddings)
HUGGINGFACE_API_KEY=

# ── OAuth (at least ONE required for login) ──────────────────
# Google OAuth — https://console.cloud.google.com/apis/credentials
# Create OAuth 2.0 Client ID → Web Application
# Authorized redirect URIs: http://localhost:8000/api/v1/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth — https://github.com/settings/developers → New OAuth App
# Authorization callback URL: http://localhost:8000/api/v1/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

OAUTH_REDIRECT_BASE_URL=http://localhost:8000

# ── Search (Optional — DuckDuckGo used by default if not set) ─
# Tavily — https://tavily.com  (Free: 1000 searches/month, better quality)
TAVILY_API_KEY=

# ── External APIs (Optional — enhance resource discovery) ────
# GitHub token — https://github.com/settings/tokens
# Increases GitHub API rate limit from 60 to 5000 requests/hour
GITHUB_TOKEN=

# YouTube Data API — https://console.cloud.google.com (Free: 10000 units/day)
# Enables video resource discovery
YOUTUBE_API_KEY=

# ── Resource Discovery Settings ──────────────────────────────
RESOURCE_REFRESH_INTERVAL_HOURS=168   # How often to refresh resources (default: weekly)
MIN_RESOURCE_TRUST_SCORE=30           # Exclude resources below this score (0-100)
MAX_RESOURCES_PER_TOPIC=50            # Max resources stored per topic
SEARCH_RESULTS_PER_SOURCE=10          # Results to fetch from each source

# ── Seed Data ────────────────────────────────────────────────
AUTO_SEED_ON_STARTUP=true             # Load AI taxonomy on first run

# ── Infrastructure (auto-set by Docker Compose) ──────────────
# Only change these if running services manually (not via Docker)
# DATABASE_URL=postgresql+asyncpg://erudios:erudios@localhost:5432/erudios
# REDIS_URL=redis://localhost:6379/0
# QDRANT_URL=http://localhost:6333
